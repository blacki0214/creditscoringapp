# VNPT eKYC API Credentials
# Copy this file to .env and fill in your actual credentials

# Token ID from VNPT Dashboard
VNPT_TOKEN_ID=

# Token Key (Public Key)
VNPT_TOKEN_KEY=

# Public Key CA
VNPT_PUBLIC_KEY_CA=

# Initial Access Token (Bearer token from VNPT)
# Format: bearer eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...
VNPT_ACCESS_TOKEN=

# =========================
# TEST ENVIRONMENT SETTINGS
# =========================
# Enable test-account bypass mode (true/false)
TEST_ENV_ENABLED=false

# Comma-separated emails that are treated as test accounts.
# These accounts will bypass eKYC and go straight to form filling.
# Example: tester1@company.com,tester2@company.com
TEST_ACCOUNT_EMAILS=quoctest@gmail.com