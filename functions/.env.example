# Copy this file to functions/.env.local (for emulator) or set vars in Firebase env.
# These values are required by sendStudentVerificationEmail function.

# Gmail address used to send verification emails
SMTP_USER=yourgmail@gmail.com

# Gmail App Password (16 chars, generated after enabling 2-step verification)
SMTP_APP_PASSWORD=xxxxxxxxxxxxxxxx

# From address shown in sent emails (usually same as SMTP_USER)
SMTP_FROM=yourgmail@gmail.com
